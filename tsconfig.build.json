{
  "compilerOptions": {
    "target": "es2016",
    "jsx": "preserve",
    "jsxImportSource": "essor",
    "lib": ["ES2022", "DOM"],
    "experimentalDecorators": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "declaration": true,
    "declarationMap": true,
    "newLine": "LF",
    "sourceMap": false,
    "stripInternal": true,
    "esModuleInterop": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["packages/*/src/**/*", "globals.d.ts"],
  "exclude": [
    "**/node_modules/**",
    "dist",
    "./dist/**/*",
    "docs",
    "examples",
    "**/test/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
