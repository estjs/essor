exports[`transform symbol > should work with object pattern 1`] = `
"import { signal as _signal$, computed as _computed$ } from "essor";
let $obj = _signal$({
  a: 1,
  b: 2
});
const $a = _computed$(() => $obj.value.a),
  b = $obj.value.b;
let $arr = _signal$([1, 2]);
const $c = _computed$(() => $arr.value[0]),
  d = $arr.value[1];
let $nested = _signal$([{
  d: 1,
  e: 2
}]);
const $d = _computed$(() => $nested.value[0].d),
  e = $nested.value[0].e;
console.log($a.value, b);
console.log($c.value, d);
console.log($d.value, e);"
`;

