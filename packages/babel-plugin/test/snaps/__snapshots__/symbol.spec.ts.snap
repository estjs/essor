exports[`transform symbol > should keep reactivity when destructuring a signal array 1`] = `
"import { signal as _signal$, computed as _computed$ } from "essor";
let $items = _signal$([1, 2, 3]);
const $first = _computed$(() => $items.value[0]),
  second = $items.value[1];
console.log($first.value, second);"
`;

