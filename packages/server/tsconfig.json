{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "stripInternal": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "../globals.d.ts"],
  "exclude": [
    "**/node_modules/**",
    "dist",
    "./dist/**/*",
    "docs",
    "examples",
    "**/test/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
