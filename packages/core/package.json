{
  "name": "essor",
  "version": "0.0.16-beta.8",
  "description": "",
  "type": "module",
  "keywords": [],
  "license": "MIT",
  "homepage": "https://github.com/estjs/essor",
  "bugs": "https://github.com/estjs/essor/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estjs/essor.git"
  },
  "author": "jiangxd <jiangxd2016@gmail.com>",
  "funding": "https://github.com/sponsors/estjs",
  "files": [
    "dist",
    "jsx-runtime.d.ts",
    "types"
  ],
  "main": "./dist/essor.cjs",
  "module": "./dist/essor.js",
  "types": "./dist/essor.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./dist/essor.d.ts",
        "require": "./dist/essor.dev.cjs",
        "import": "./dist/essor.dev.js"
      },
      "types": "./dist/essor.d.ts",
      "require": "./dist/essor.cjs",
      "import": "./dist/essor.js"
    },
    "./server": {
      "development": {
        "types": "./dist/server.d.ts",
        "require": "./dist/server.dev.cjs",
        "import": "./dist/server.dev.js"
      },
      "types": "./dist/server.d.ts",
      "require": "./dist/server.cjs",
      "import": "./dist/server.js"
    },
    "./jsx-runtime": {
      "types": "./jsx-runtime.d.ts",
      "default": "./dist/essor.js"
    },
    "./jsx-dev-runtime": {
      "types": "./types/jsx.d.ts",
      "default": "./dist/essor.dev.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/essor.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "unpkg": "dist/essor.js",
  "jsdelivr": "dist/essor.js",
  "scripts": {
    "build": "tsup && cross-env NODE_ENV=production tsup --clean=false",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@estjs/server": "workspace:*",
    "@estjs/signals": "workspace:*",
    "@estjs/template": "workspace:*",
    "csstype": "^3.2.3"
  }
}
