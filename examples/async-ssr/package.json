{
  "name": "essor-example-async-ssr",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "dev:ssr": "node server.js",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "preview": "cross-env NODE_ENV=production node server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@estjs/server": "workspace:*",
    "essor": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "typescript": "^7.0.2",
    "unplugin-essor": "workspace:*",
    "vite": "^8.1.5"
  }
}
