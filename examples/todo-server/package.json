    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "unplugin-essor": "workspace:*",
    "vite": "^8.1.0",
    "vite-plugin-inspect": "^11.4.1",
    "vitest": "^4.1.9"
